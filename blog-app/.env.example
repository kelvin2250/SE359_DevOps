# ============================================
# MiniBlog - Environment Configuration
# ============================================
# Copy this file to .env and adjust values:
#   cp .env.example .env
# ============================================

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=blogdb

# --- Backend ---
# Database connection string (Docker network: use service name "db")
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
# Host port for backend API (change if port conflict)
BACKEND_PORT=8002

# --- Frontend ---
# Host port for frontend Nginx
FRONTEND_PORT=8080
